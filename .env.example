# ─────────────────────────────────────────────────────────────────────────────
# BenzolPro — omgevingsvariabelen
# Kopieer dit bestand naar `.env.local` (lokaal) of zet de waarden in je
# hostingplatform (Vercel/Netlify → Project → Environment Variables).
# Variabelen met NEXT_PUBLIC_ zijn zichtbaar in de browser; de rest is server-only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domein & SEO (VERPLICHT vóór livegang) ──────────────────────────────────
# Je echte domein. Bepaalt alle canonical-URLs, de sitemap en structured data.
NEXT_PUBLIC_SITE_URL=https://www.benzolpro.nl

# ── Betalingen — Mollie (VERPLICHT om te kunnen verkopen) ────────────────────
# Maak een account op https://www.mollie.com, activeer iDEAL/creditcard, en zet
# hier je LIVE-sleutel (live_...). Gebruik test_... om eerst te testen zonder
# echte afschrijving. De sleutel bepaalt automatisch test- of live-modus.
MOLLIE_API_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Bestellingen & offertes ontvangen (kies e-mail OF webhook) ───────────────
# Optie A — e-mail via Resend (https://resend.com, gratis tier):
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Geverifieerd afzenderadres (domein verifiëren in Resend):
MAIL_FROM=BenzolPro <orders@benzolpro.nl>
# Waar bestellingen/offertes/aanmeldingen naartoe gaan (jouw postvak):
ORDER_EMAIL=orders@benzolpro.nl

# Optie B — of stuur alles naar een webhook (Zapier/Make/eigen endpoint):
# ORDER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy

# ── Bedrijfsgegevens (VERPLICHT voor juridische pagina's + SEO) ──────────────
NEXT_PUBLIC_COMPANY_NAME=Benzol Lubricants B.V.
NEXT_PUBLIC_COMPANY_KVK=12345678
NEXT_PUBLIC_COMPANY_VAT=NL123456789B01
NEXT_PUBLIC_COMPANY_IBAN=
NEXT_PUBLIC_COMPANY_PHONE=+31 (0)20 000 0000
NEXT_PUBLIC_CONTACT_EMAIL=hallo@benzolpro.nl
NEXT_PUBLIC_COMPANY_STREET=Voorbeeldstraat 1
NEXT_PUBLIC_COMPANY_POSTAL=1000 AA
NEXT_PUBLIC_COMPANY_CITY=Amsterdam
NEXT_PUBLIC_COMPANY_COUNTRY=NL

# Datum "laatst bijgewerkt" op de juridische pagina's (YYYY-MM-DD):
NEXT_PUBLIC_LEGAL_UPDATED=2026-07-06

# ── Analytics (optioneel) ────────────────────────────────────────────────────
# Google Analytics 4: plaatst cookies → laadt PAS na toestemming (cookiemelding
# verschijnt automatisch zodra dit is ingevuld). Laat leeg om geen GA te gebruiken.
NEXT_PUBLIC_GA_ID=

# Plausible (cookieloos, privacyvriendelijk, geen toestemming nodig): zet je domein.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Google Search Console (optioneel) ────────────────────────────────────────
# De verificatie-string uit de "HTML-tag"-methode (alleen het content-deel).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Reviews-opslag (optioneel) ───────────────────────────────────────────────
# Blijvende, gedeelde productreviews via Vercel KV / Upstash Redis. Zonder deze
# variabelen worden reviews alleen in de browser van de bezoeker bewaard.
# Op Vercel: Storage → KV toevoegen → deze variabelen worden automatisch gezet.
KV_REST_API_URL=
KV_REST_API_TOKEN=
